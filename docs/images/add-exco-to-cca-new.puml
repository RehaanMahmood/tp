@startuml add-exco-to-cca

' Match the styling of the add-event diagram
skinparam defaultFontSize 13
skinparam SequenceArrowThickness 1.5
skinparam SequenceParticipantBackgroundColor #f9f9f9

title add-exco-to-cca Command

actor ":User" as User
participant "ccaLedger : CcaLedger" as CL
participant "ui : Ui" as Ui
participant "parser : Parser" as Parser
participant "command : AddExcoCmd" as Command
participant "ccaManager : CcaManager" as CcaManager
participant "residentManager : ResidentManager" as ResidentManager

ref over User, CL, Ui, Parser, Command
  SD_CommandExecution
end ref

' Data Retrieval spread out to increase width
Command -> CcaManager : getCCAList()
activate CcaManager
CcaManager --> Command : ccaList : ArrayList<Cca>
deactivate CcaManager

Command -> ResidentManager : getResidentList()
activate ResidentManager
ResidentManager --> Command : residentList : ArrayList<Resident>
deactivate ResidentManager

' Logic Flow
alt CCA / Resident not found
    Command -> Ui : showError("Not found")
    activate Ui
    Ui --> Command
    deactivate Ui
else Resident already in CCA
    Command -> Ui : showError("Already in CCA")
    activate Ui
    Ui --> Command
    deactivate Ui
else Success
    ' Explicit internal call
    Command -> Command : updateDomainModels(res, cca)
    activate Command
    deactivate Command

    Command -> Ui : showMessage("Added as EXCO...")
    activate Ui
    Ui --> Command
    deactivate Ui
end

Command --> CL
deactivate Command

@enduml